# .env.lite.example — GPU 없는 노트북 경량 배포판 기본값
#
# 사용법: 이 파일을 .env로 복사한 뒤 그대로 사용
#   cp .env.lite.example .env
#   docker compose build && docker compose up -d
#
# 설계 근거: docs/advancement/2.scenario/scenario_1.md, docs/advancement/3.confirmed/scenario_1_confirmed.md

# 로컬(Ollama) LLM 사용 — Claude API로 되돌리려면 anthropic으로 바꾸고 CLAUDE_API_KEY만 채우면 됨
LLM_PROVIDER=local
LLM_LOCAL_URL=http://ollama:11434
LLM_LOCAL_MODEL=qwen2.5-coder:7b
LLM_LOCAL_API_KEY=
# 코드 분석은 창작이 아니라 사실 추출 작업이라 낮게 잡음 — 소형 모델이 시스템 프롬프트의
# 예시 문장을 베끼거나 근거 없는 내용을 지어내는 걸 줄여준다(2026-07-23 실측 기반 조정).
LLM_LOCAL_TEMPERATURE=0.2

# ollama/chroma 컨테이너를 기본으로 함께 띄움(이 경량판은 로컬 LLM이 필수라 항상 on)
COMPOSE_PROFILES=llm-rag

# local 모드에선 안 쓰이므로 비워둬도 됨 — anthropic으로 전환할 때만 채우면 됨
CLAUDE_API_KEY=
